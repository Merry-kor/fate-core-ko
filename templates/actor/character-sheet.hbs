<div class="fate-sheet">

  {{!-- 헤더 --}}
  <header class="fate-sheet__header">
    <div class="fate-header__portrait">
      <img class="fate-header__img" src="{{actor.img}}" alt="{{actor.name}}" data-edit="img">
    </div>
    <div class="fate-header__info">
      <input class="fate-header__name" type="text" name="name" value="{{actor.name}}"
        placeholder="{{localize 'FATE.Sheet.Name'}}">
      <div class="fate-header__fatepoints">
        <div class="fate-fp__group">
          <label class="fate-fp__label">{{localize "FATE.Sheet.FatePoints"}}</label>
          <div class="fate-fp__controls">
            <button class="fate-fp__btn" type="button" data-action="adjustFP" data-delta="-1">−</button>
            <input class="fate-fp__value" type="number" name="system.fatepoints.current"
              value="{{system.fatepoints.current}}" min="0">
            <button class="fate-fp__btn" type="button" data-action="adjustFP" data-delta="1">+</button>
          </div>
        </div>
        <div class="fate-fp__group">
          <label class="fate-fp__label">{{localize "FATE.Sheet.Refresh"}}</label>
          <input class="fate-fp__refresh" type="number" name="system.fatepoints.refresh"
            value="{{system.fatepoints.refresh}}" min="1">
        </div>
      </div>
    </div>
  </header>

  {{!-- 바디 --}}
  <div class="fate-sheet__body">

    {{!-- 왼쪽 열 --}}
    <div class="fate-sheet__left">

      {{!-- 면모 --}}
      <section class="fate-section">
        <div class="fate-section__header">
          <h2 class="fate-section__title">{{localize "FATE.Sheet.Aspects"}}</h2>
          <button class="fate-section__add" type="button" data-action="addItem" data-type="aspect"
            title="{{localize 'FATE.Actions.Add'}}">+</button>
        </div>
        <ul class="fate-list fate-aspects">
          {{#each aspects as |aspect|}}
          <li class="fate-list__item fate-aspect" data-item-id="{{aspect.id}}">
            <input class="fate-aspect__value" type="text"
              name="items.{{aspect.id}}.system.label"
              value="{{aspect.system.label}}"
              placeholder="{{localize 'FATE.Item.Aspect.Label'}}">
            <div class="fate-item__actions">
              <button class="fate-btn fate-btn--icon" type="button" data-action="editItem"
                title="{{localize 'FATE.Actions.Edit'}}"><i class="fa fa-cog"></i></button>
              <button class="fate-btn fate-btn--icon fate-btn--danger" type="button" data-action="deleteItem"
                title="{{localize 'FATE.Actions.Delete'}}"><i class="fa fa-trash"></i></button>
            </div>
          </li>
          {{/each}}
        </ul>
      </section>

      {{!-- 스트레스 --}}
      <section class="fate-section">
        <div class="fate-section__header">
          <h2 class="fate-section__title">{{localize "FATE.Sheet.StressTracks"}}</h2>
          <button class="fate-section__add" type="button" data-action="addItem" data-type="stress"
            title="{{localize 'FATE.Actions.Add'}}">+</button>
        </div>
        {{#each stressTracks as |track|}}
        <div class="fate-stress" data-item-id="{{track.id}}">
          <div class="fate-stress__header">
            <span class="fate-stress__label">{{track.name}}</span>
            <div class="fate-item__actions">
              <button class="fate-btn fate-btn--icon" type="button" data-action="editItem"
                title="{{localize 'FATE.Actions.Edit'}}"><i class="fa fa-cog"></i></button>
              <button class="fate-btn fate-btn--icon fate-btn--danger" type="button" data-action="deleteItem"
                title="{{localize 'FATE.Actions.Delete'}}"><i class="fa fa-trash"></i></button>
            </div>
          </div>
          <div class="fate-stress__boxes">
            {{#each_times track.system.size}}
            <label class="fate-stress__box">
              <input type="checkbox"
                name="items.{{../track.id}}.system.checked.{{@index}}"
                {{checked (lookup ../track.system.checked @index)}}>
              <span class="fate-stress__pip"></span>
            </label>
            {{/each_times}}
          </div>
        </div>
        {{/each}}
      </section>

      {{!-- 타격 --}}
      <section class="fate-section">
        <div class="fate-section__header">
          <h2 class="fate-section__title">{{localize "FATE.Sheet.Consequences"}}</h2>
          <button class="fate-section__add" type="button" data-action="addItem" data-type="consequence"
            title="{{localize 'FATE.Actions.Add'}}">+</button>
        </div>
        <ul class="fate-list fate-consequences">
          {{#each consequences as |con|}}
          <li class="fate-list__item fate-consequence" data-item-id="{{con.id}}">
            <span class="fate-consequence__severity">{{con.system.severity}}</span>
            <input class="fate-consequence__value" type="text"
              name="items.{{con.id}}.system.value"
              value="{{con.system.value}}"
              placeholder="{{con.name}}">
            <div class="fate-item__actions">
              <button class="fate-btn fate-btn--icon" type="button" data-action="editItem"
                title="{{localize 'FATE.Actions.Edit'}}"><i class="fa fa-cog"></i></button>
              <button class="fate-btn fate-btn--icon fate-btn--danger" type="button" data-action="deleteItem"
                title="{{localize 'FATE.Actions.Delete'}}"><i class="fa fa-trash"></i></button>
            </div>
          </li>
          {{/each}}
        </ul>
      </section>

    </div>

    {{!-- 오른쪽 열 (탭) --}}
    <div class="fate-sheet__right">
      <nav class="fate-tabs">
        <a class="fate-tabs__tab active" data-tab="skills">{{localize "FATE.Sheet.Tabs.Skills"}}</a>
        <a class="fate-tabs__tab" data-tab="extras">{{localize "FATE.Sheet.Tabs.Extras"}}</a>
        <a class="fate-tabs__tab" data-tab="bio">{{localize "FATE.Sheet.Tabs.Bio"}}</a>
      </nav>

      {{!-- 기능 & 특기 탭 --}}
      <div class="fate-tab-content active" data-tab="skills">

        <section class="fate-section">
          <div class="fate-section__header">
            <h3 class="fate-section__title">{{localize "FATE.Sheet.Skills"}}</h3>
            <button class="fate-section__add" type="button" data-action="addItem" data-type="skill"
              title="{{localize 'FATE.Actions.Add'}}">+</button>
          </div>
          <ul class="fate-skill-ladder">
            {{#each skills as |skill|}}
            <li class="fate-skill" data-item-id="{{skill.id}}">
              <span class="fate-skill__rank">{{lookup ../ladder skill.system.rank}}</span>
              <span class="fate-skill__name">{{skill.name}}</span>
              <div class="fate-item__actions">
                <button class="fate-btn fate-btn--roll" type="button" data-action="rollSkill"
                  title="{{localize 'FATE.Actions.Roll'}}">굴리기</button>
                <button class="fate-btn fate-btn--icon" type="button" data-action="editItem"
                  title="{{localize 'FATE.Actions.Edit'}}"><i class="fa fa-cog"></i></button>
                <button class="fate-btn fate-btn--icon fate-btn--danger" type="button" data-action="deleteItem"
                  title="{{localize 'FATE.Actions.Delete'}}"><i class="fa fa-trash"></i></button>
              </div>
            </li>
            {{/each}}
          </ul>
        </section>

        <section class="fate-section">
          <div class="fate-section__header">
            <h3 class="fate-section__title">{{localize "FATE.Sheet.Stunts"}}</h3>
            <button class="fate-section__add" type="button" data-action="addItem" data-type="stunt"
              title="{{localize 'FATE.Actions.Add'}}">+</button>
          </div>
          <ul class="fate-list fate-stunts">
            {{#each stunts as |stunt|}}
            <li class="fate-list__item fate-stunt" data-item-id="{{stunt.id}}">
              <div class="fate-stunt__header">
                <span class="fate-stunt__name">{{stunt.name}}</span>
                <div class="fate-item__actions">
                  <button class="fate-btn fate-btn--icon" type="button" data-action="editItem"
                    title="{{localize 'FATE.Actions.Edit'}}"><i class="fa fa-cog"></i></button>
                  <button class="fate-btn fate-btn--icon fate-btn--danger" type="button" data-action="deleteItem"
                    title="{{localize 'FATE.Actions.Delete'}}"><i class="fa fa-trash"></i></button>
                </div>
              </div>
              {{#if stunt.system.summary}}
              <p class="fate-stunt__summary">{{stunt.system.summary}}</p>
              {{/if}}
            </li>
            {{/each}}
          </ul>
        </section>

      </div>

      {{!-- 특수항목 탭 --}}
      <div class="fate-tab-content" data-tab="extras">
        <section class="fate-section">
          <div class="fate-section__header">
            <h3 class="fate-section__title">{{localize "FATE.Sheet.Extras"}}</h3>
            <button class="fate-section__add" type="button" data-action="addItem" data-type="extra"
              title="{{localize 'FATE.Actions.Add'}}">+</button>
          </div>
          <ul class="fate-list">
            {{#each extras as |extra|}}
            <li class="fate-list__item fate-extra" data-item-id="{{extra.id}}">
              <span class="fate-extra__name">{{extra.name}}</span>
              <div class="fate-item__actions">
                <button class="fate-btn fate-btn--icon" type="button" data-action="editItem"
                  title="{{localize 'FATE.Actions.Edit'}}"><i class="fa fa-cog"></i></button>
                <button class="fate-btn fate-btn--icon fate-btn--danger" type="button" data-action="deleteItem"
                  title="{{localize 'FATE.Actions.Delete'}}"><i class="fa fa-trash"></i></button>
              </div>
            </li>
            {{/each}}
          </ul>
        </section>
      </div>

      {{!-- 일대기 탭 --}}
      <div class="fate-tab-content" data-tab="bio">
        <section class="fate-section fate-section--bio">
          <label class="fate-label">{{localize "FATE.Sheet.Biography"}}</label>
          <div class="fate-editor">
            {{editor system.biography target="system.biography" button=false editable=editable}}
          </div>
        </section>
        <section class="fate-section">
          <label class="fate-label">{{localize "FATE.Sheet.Notes"}}</label>
          <textarea class="fate-textarea" name="system.notes" rows="4">{{system.notes}}</textarea>
        </section>
      </div>

    </div>
  </div>
</div>

<script>
  (function() {
    const sheet = document.currentScript.closest(".fate-sheet") || document.querySelector(".fate-sheet");
    if (!sheet) return;
    sheet.querySelectorAll(".fate-tabs__tab").forEach(tab => {
      tab.addEventListener("click", e => {
        const target = e.currentTarget.dataset.tab;
        sheet.querySelectorAll(".fate-tabs__tab").forEach(t => t.classList.remove("active"));
        sheet.querySelectorAll(".fate-tab-content").forEach(c => c.classList.remove("active"));
        e.currentTarget.classList.add("active");
        sheet.querySelector(`.fate-tab-content[data-tab="${target}"]`)?.classList.add("active");
      });
    });
  })();
</script>
