{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/fate/**",
              "components/stage/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:IBM Plex Mono|Noto Sans KR|Noto Serif KR))/i]",
        "message": "Font not provided by the design system. Available: IBM Plex Mono, Noto Sans KR, Noto Serif KR."
      },
      {
        "selector": "JSXOpeningElement[name.name='ActorHUD'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|portrait|division|fatePoints|onStage|active|onToggleStage|onSpeak|key|ref|className|style|children)$/]",
        "message": "<ActorHUD> doesn't accept that prop. Declared props: name, portrait, division, fatePoints, onStage, active, onToggleStage, onSpeak."
      },
      {
        "selector": "JSXOpeningElement[name.name='AspectChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|type|tag|invokes|stack|onInvoke|actions|key|ref|className|style|children)$/]",
        "message": "<AspectChip> doesn't accept that prop. Declared props: label, type, tag, invokes, stack, onInvoke, actions."
      },
      {
        "selector": "JSXOpeningElement[name.name='AspectChip'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:identity|trouble|general|situation|longterm|stack)$/]",
        "message": "<AspectChip> type must be one of 'identity' | 'trouble' | 'general' | 'situation' | 'longterm' | 'stack'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|name|size|shape|ring|badge|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, name, size, shape, ring, badge."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='shape'] > Literal[value!=/^(?:circle|frame)$/]",
        "message": "<Avatar> shape must be one of 'circle' | 'frame'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='ring'] > Literal[value!=/^(?:none|gold|crimson|active)$/]",
        "message": "<Avatar> ring must be one of 'none' | 'gold' | 'crimson' | 'active'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|variant|size|uppercase|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, variant, size, uppercase."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:gold|crimson|steel|success|tie|fail|violet|teal|blue)$/]",
        "message": "<Badge> tone must be one of 'gold' | 'crimson' | 'steel' | 'success' | 'tie' | 'fail' | 'violet' | 'teal' | 'blue'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:solid|soft|outline)$/]",
        "message": "<Badge> variant must be one of 'solid' | 'soft' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Badge> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|disabled|icon|block|onClick|type|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, disabled, icon, block, onClick, type."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:gold|crimson|steel|ghost)$/]",
        "message": "<Button> variant must be one of 'gold' | 'crimson' | 'steel' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChatLine'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|speaker|portrait|time|accent|children|key|ref|className|style|children)$/]",
        "message": "<ChatLine> doesn't accept that prop. Declared props: variant, speaker, portrait, time, accent, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChatLine'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:narration|dialogue|narrator|system)$/]",
        "message": "<ChatLine> variant must be one of 'narration' | 'dialogue' | 'narrator' | 'system'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FateDie'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|size|key|ref|className|style|children)$/]",
        "message": "<FateDie> doesn't accept that prop. Declared props: value, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='FatePoints'] > JSXAttribute > JSXIdentifier[name!=/^(?:current|refresh|onAdjust|key|ref|className|style|children)$/]",
        "message": "<FatePoints> doesn't accept that prop. Declared props: current, refresh, onAdjust."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|size|title|onClick|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: children, tone, size, title, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:steel|gold|crimson)$/]",
        "message": "<IconButton> tone must be one of 'steel' | 'gold' | 'crimson'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<IconButton> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='LadderBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:rank|showLabel|size|key|ref|className|style|children)$/]",
        "message": "<LadderBadge> doesn't accept that prop. Declared props: rank, showLabel, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='LadderBadge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<LadderBadge> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='RollCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:actor|portrait|skill|dice|modifier|difficulty|action|key|ref|className|style|children)$/]",
        "message": "<RollCard> doesn't accept that prop. Declared props: actor, portrait, skill, dice, modifier, difficulty, action."
      },
      {
        "selector": "JSXOpeningElement[name.name='SceneCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|chapter|thumbnail|active|onActivate|key|ref|className|style|children)$/]",
        "message": "<SceneCard> doesn't accept that prop. Declared props: name, chapter, thumbnail, active, onActivate."
      },
      {
        "selector": "JSXOpeningElement[name.name='SkillRung'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|rank|onRoll|actions|key|ref|className|style|children)$/]",
        "message": "<SkillRung> doesn't accept that prop. Declared props: name, rank, onRoll, actions."
      },
      {
        "selector": "JSXOpeningElement[name.name='StressTrack'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|size|checked|onToggle|actions|key|ref|className|style|children)$/]",
        "message": "<StressTrack> doesn't accept that prop. Declared props: label, size, checked, onToggle, actions."
      },
      {
        "selector": "JSXOpeningElement[name.name='StuntCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|summary|approach|mystery|actions|key|ref|className|style|children)$/]",
        "message": "<StuntCard> doesn't accept that prop. Declared props: name, summary, approach, mystery, actions."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|label|icon|count|key|ref|className|style|children)$/]",
        "message": "<TabItem> doesn't accept that prop. Declared props: id, label, icon, count."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
